{
  "info": {
    "name": "JobsMonitor API",
    "description": "Yammi Jobs Monitor — all public API endpoints. Use the collection variable {{base_url}} to point at your test app (default http://localhost:8090 for Laravel 13, http://localhost:8080 for Laravel 10).\n\nMake sure `JOBS_MONITOR_API_ENABLED=true` is set in the host app's .env — the API is disabled by default.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Jobs",
      "description": "List paginated job records with filters, sorting and search.",
      "item": [
        {
          "name": "All jobs (defaults)",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/api/jobs-monitor/jobs?period=24h",
              "host": ["{{base_url}}"],
              "path": ["api", "jobs-monitor", "jobs"],
              "query": [
                {"key": "period", "value": "24h", "description": "1m, 5m, 30m, 1h, 6h, 24h, 7d, 30d, all"}
              ]
            }
          }
        },
        {
          "name": "All jobs (all time)",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/api/jobs-monitor/jobs?period=all",
              "host": ["{{base_url}}"],
              "path": ["api", "jobs-monitor", "jobs"],
              "query": [{"key": "period", "value": "all"}]
            }
          }
        },
        {
          "name": "Search by job class",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/api/jobs-monitor/jobs?period=all&search=Invoice",
              "host": ["{{base_url}}"],
              "path": ["api", "jobs-monitor", "jobs"],
              "query": [
                {"key": "period", "value": "all"},
                {"key": "search", "value": "Invoice", "description": "Case-insensitive substring match on job_class"}
              ]
            }
          }
        },
        {
          "name": "Filter by status",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/api/jobs-monitor/jobs?period=all&status=failed",
              "host": ["{{base_url}}"],
              "path": ["api", "jobs-monitor", "jobs"],
              "query": [
                {"key": "period", "value": "all"},
                {"key": "status", "value": "failed", "description": "processing | processed | failed"}
              ]
            }
          }
        },
        {
          "name": "Filter by queue",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/api/jobs-monitor/jobs?period=all&queue=default",
              "host": ["{{base_url}}"],
              "path": ["api", "jobs-monitor", "jobs"],
              "query": [
                {"key": "period", "value": "all"},
                {"key": "queue", "value": "default", "description": "Exact match on the queue column"}
              ]
            }
          }
        },
        {
          "name": "Filter by connection",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/api/jobs-monitor/jobs?period=all&connection=database",
              "host": ["{{base_url}}"],
              "path": ["api", "jobs-monitor", "jobs"],
              "query": [
                {"key": "period", "value": "all"},
                {"key": "connection", "value": "database", "description": "redis | database | sqs | sync | ..."}
              ]
            }
          }
        },
        {
          "name": "Filter by failure category",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/api/jobs-monitor/jobs?period=all&failure_category=transient",
              "host": ["{{base_url}}"],
              "path": ["api", "jobs-monitor", "jobs"],
              "query": [
                {"key": "period", "value": "all"},
                {"key": "failure_category", "value": "transient", "description": "transient | permanent | critical | unknown"}
              ]
            }
          }
        },
        {
          "name": "Combined filters",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/api/jobs-monitor/jobs?period=all&status=failed&queue=default&failure_category=transient",
              "host": ["{{base_url}}"],
              "path": ["api", "jobs-monitor", "jobs"],
              "query": [
                {"key": "period", "value": "all"},
                {"key": "status", "value": "failed"},
                {"key": "queue", "value": "default"},
                {"key": "failure_category", "value": "transient"}
              ]
            }
          }
        },
        {
          "name": "Sort by duration (longest first)",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/api/jobs-monitor/jobs?period=all&sort=duration_ms&dir=desc",
              "host": ["{{base_url}}"],
              "path": ["api", "jobs-monitor", "jobs"],
              "query": [
                {"key": "period", "value": "all"},
                {"key": "sort", "value": "duration_ms", "description": "started_at | status | duration_ms | job_class"},
                {"key": "dir", "value": "desc", "description": "asc | desc"}
              ]
            }
          }
        },
        {
          "name": "Sort by job class (A→Z)",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/api/jobs-monitor/jobs?period=all&sort=job_class&dir=asc",
              "host": ["{{base_url}}"],
              "path": ["api", "jobs-monitor", "jobs"],
              "query": [
                {"key": "period", "value": "all"},
                {"key": "sort", "value": "job_class"},
                {"key": "dir", "value": "asc"}
              ]
            }
          }
        },
        {
          "name": "Pagination",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/api/jobs-monitor/jobs?period=all&page=1&per_page=20",
              "host": ["{{base_url}}"],
              "path": ["api", "jobs-monitor", "jobs"],
              "query": [
                {"key": "period", "value": "all"},
                {"key": "page", "value": "1", "description": "1-based"},
                {"key": "per_page", "value": "20", "description": "Max 200"}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Attempts",
      "description": "Return every stored attempt for a given job UUID, ordered by attempt number ascending. Useful for rendering a retry timeline.",
      "item": [
        {
          "name": "Get all attempts for a UUID",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/api/jobs-monitor/jobs/{{job_uuid}}/attempts",
              "host": ["{{base_url}}"],
              "path": ["api", "jobs-monitor", "jobs", "{{job_uuid}}", "attempts"]
            }
          }
        }
      ]
    },
    {
      "name": "Failures",
      "description": "Shortcut endpoint that always filters to status=failed. Still honors queue, connection, failure_category, sort, search and pagination.",
      "item": [
        {
          "name": "All failures",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/api/jobs-monitor/failures?period=all",
              "host": ["{{base_url}}"],
              "path": ["api", "jobs-monitor", "failures"],
              "query": [{"key": "period", "value": "all"}]
            }
          }
        },
        {
          "name": "Failures by category",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/api/jobs-monitor/failures?period=all&failure_category=permanent",
              "host": ["{{base_url}}"],
              "path": ["api", "jobs-monitor", "failures"],
              "query": [
                {"key": "period", "value": "all"},
                {"key": "failure_category", "value": "permanent"}
              ]
            }
          }
        },
        {
          "name": "Failures on a specific queue",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/api/jobs-monitor/failures?period=24h&queue=emails",
              "host": ["{{base_url}}"],
              "path": ["api", "jobs-monitor", "failures"],
              "query": [
                {"key": "period", "value": "24h"},
                {"key": "queue", "value": "emails"}
              ]
            }
          }
        },
        {
          "name": "Failures sorted by newest",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/api/jobs-monitor/failures?period=all&sort=started_at&dir=desc",
              "host": ["{{base_url}}"],
              "path": ["api", "jobs-monitor", "failures"],
              "query": [
                {"key": "period", "value": "all"},
                {"key": "sort", "value": "started_at"},
                {"key": "dir", "value": "desc"}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Stats",
      "description": "Aggregate stats for a single job class over a time period.",
      "item": [
        {
          "name": "Stats for a job class",
          "request": {
            "method": "GET",
            "header": [{"key": "Accept", "value": "application/json"}],
            "url": {
              "raw": "{{base_url}}/api/jobs-monitor/stats?period=24h&job_class=App\\Jobs\\SendInvoice",
              "host": ["{{base_url}}"],
              "path": ["api", "jobs-monitor", "stats"],
              "query": [
                {"key": "period", "value": "24h"},
                {"key": "job_class", "value": "App\\Jobs\\SendInvoice", "description": "Required — fully qualified job class"}
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8090",
      "description": "Laravel 13 test app. Switch to http://localhost:8080 for Laravel 10."
    },
    {
      "key": "job_uuid",
      "value": "",
      "description": "Set this to the UUID of a job you want to inspect attempts for."
    }
  ]
}
